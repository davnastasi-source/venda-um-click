<script>
var PRICES = {
  'vip_10x':   {unit:8625,currency:'BRL'},
  'vip_6x':    {unit:8250,currency:'BRL'},
  'vip_avista':{unit:7500,currency:'BRL'}
};

function fmtTotal(unit,qty,currency){
  var t = unit*qty;
  return (currency==='USD'?'USD ':'R$ ')+t.toLocaleString('pt-BR');
}
function updateTotal(){
  var v = document.getElementById('f-ingresso').value;
  var qty = parseInt(document.getElementById('f-qty').value)||1;
  var tot = document.getElementById('f-total');
  tot.value = (v && PRICES[v]) ? fmtTotal(PRICES[v].unit,qty,PRICES[v].currency) : '';
}
function changeQty(delta){
  var el = document.getElementById('f-qty');
  el.value = Math.min(10,Math.max(1,(parseInt(el.value)||1)+delta));
  updateTotal();
}
function selectIngresso(card){
  document.querySelectorAll('.price-card').forEach(function(c){c.classList.remove('selected');});
  card.classList.add('selected');
  var v = card.dataset.value;
  document.getElementById('f-ingresso').value = v;
  var pg = document.getElementById('f-pagamento');
  if(v==='vip_avista')  pg.value='pix';
  else if(v==='vip_6x') pg.value='cc_6x';
  else if(v==='vip_10x')pg.value='cc_10x';
  updateTotal();
  document.getElementById('checkout').scrollIntoView({behavior:'smooth',block:'start'});
}
document.getElementById('f-ingresso').addEventListener('change',function(){
  var v=this.value;
  var pg=document.getElementById('f-pagamento');
  if(v==='vip_avista')  pg.value='pix';
  else if(v==='vip_6x') pg.value='cc_6x';
  else if(v==='vip_10x')pg.value='cc_10x';
  document.querySelectorAll('.price-card').forEach(function(c){
    c.classList.toggle('selected',c.dataset.value===v);
  });
  updateTotal();
});

document.getElementById('vip-form').addEventListener('submit',function(e){
  e.preventDefault();
  var nome     = document.getElementById('f-nome').value.trim();
  var email    = document.getElementById('f-email').value.trim();
  var whats    = document.getElementById('f-whats').value.trim();
  var doc      = document.getElementById('f-doc').value.trim();
  var endereco = document.getElementById('f-endereco').value.trim();
  var ingresso = document.getElementById('f-ingresso').value;
  var pagamento= document.getElementById('f-pagamento').value;
  var qty      = document.getElementById('f-qty').value;
  var t1       = document.getElementById('f-termos1').checked;
  var t2       = document.getElementById('f-termos2').checked;
  var t3       = document.getElementById('f-termos3').checked;

  var erros=[];
  if(!nome)     erros.push('Nome completo');
  if(!email)    erros.push('E-mail');
  if(!whats)    erros.push('WhatsApp');
  if(!doc)      erros.push('CPF / Passaporte');
  if(!endereco) erros.push('Endereço');
  if(!ingresso) erros.push('Tipo de ingresso');
  if(!pagamento)erros.push('Forma de pagamento');
  if(!t1)       erros.push('Aceitar os Termos de Participação');
  if(!t2)       erros.push('Confirmar ciência das regras do retiro');
  if(!t3)       erros.push('Autorização de dados (LGPD)');

  if(erros.length){alert('Por favor, complete:\n\n• '+erros.join('\n• '));return;}

  var btn=document.getElementById('pay-btn');
  btn.disabled=true; btn.textContent='Redirecionando…';

  var paymentURL='https://condorblanco.com/pagamento-sadhana-vip-2026'
    +'?nome='+encodeURIComponent(nome)
    +'&email='+encodeURIComponent(email)
    +'&ingresso='+encodeURIComponent(ingresso)
    +'&qty='+encodeURIComponent(qty);

  setTimeout(function(){
    alert('✅ Dados VIP validados!\n\nEm produção, redirecionar para:\n'+paymentURL);
    btn.disabled=false;
    btn.textContent='✦  Garantir Ingresso VIP — Ir para Pagamento';
  },900);
});
</script>
